{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/wpggLabs/PactRide/main/schemas/event-envelope.schema.json",
  "title": "PactRide Event Envelope",
  "description": "Strict draft schema for PactRide events. event_id is computed from the canonical signing object, which excludes event_id and proofs.",
  "type": "object",
  "required": [
    "protocol",
    "version",
    "type",
    "event_id",
    "actor",
    "created_at",
    "payload",
    "proofs"
  ],
  "properties": {
    "protocol": { "const": "pactride" },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)+$"
    },
    "event_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "actor": {
      "type": "string",
      "minLength": 16,
      "maxLength": 256
    },
    "created_at": {
      "type": "integer",
      "minimum": 0
    },
    "ttl_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 604800
    },
    "ride_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "previous": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^sha256:[0-9a-f]{64}$"
      },
      "uniqueItems": true,
      "maxItems": 16,
      "default": []
    },
    "payload": {
      "type": "object"
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9.-]{2,63}/[A-Za-z0-9_.-]+$"
      },
      "additionalProperties": true,
      "maxProperties": 32
    },
    "proofs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["signer", "algorithm", "signature"],
        "properties": {
          "signer": {
            "type": "string",
            "minLength": 16,
            "maxLength": 256
          },
          "algorithm": {
            "type": "string",
            "minLength": 3,
            "maxLength": 64
          },
          "signature": {
            "type": "string",
            "minLength": 32,
            "maxLength": 2048
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "ride.request",
              "ride.withdraw",
              "ride.offer",
              "ride.counter",
              "ride.accept",
              "ride.decline",
              "ride.cancel",
              "driver.departing",
              "driver.arrived",
              "pickup.challenge",
              "pickup.proof",
              "ride.started",
              "ride.progress",
              "ride.abort",
              "ride.completed.claim",
              "ride.completed.receipt",
              "ride.disputed",
              "ride.rating",
              "identity.binding"
            ]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["ride_id"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["ride.request", "driver.availability", "ride.withdraw"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["ttl_seconds"],
        "not": { "required": ["extensions"] }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "identity.binding" }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["ttl_seconds"]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["pickup.proof", "ride.completed.receipt", "identity.binding"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "proofs": {
            "minItems": 2
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
